{
  "name": "innova/platform",
  "type": "project",
  "description": "INNOVA.TJ - Platform of Innovation and Commercialisation",
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12.0",
    "laravel/sanctum": "^4.0",
    "laravel/socialite": "^5.0",
    "spatie/laravel-permission": "^6.0",
    "intervention/image": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "fakerphp/faker": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
